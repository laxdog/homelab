{
  "uid": "rr-timing",
  "title": "RR Phase Timing",
  "tags": ["raffleraptor"],
  "timezone": "browser",
  "schemaVersion": 40,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "title": "P95 Fetch Requests (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "rr_p95_fetch_requests_ms{env=\"prod\"}",
          "legendFormat": "prod",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "rr_p95_fetch_requests_ms{env=\"staging\"}",
          "legendFormat": "staging",
          "refId": "B"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "Prometheus" }
    },
    {
