{
  "uid": "rr-worker",
  "title": "RR Worker Health",
  "tags": ["raffleraptor"],
  "timezone": "browser",
  "schemaVersion": 40,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "title": "Success Rate (5m)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "rr_success_rate_5m{env=\"prod\"}",
          "legendFormat": "prod",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "rr_success_rate_5m{env=\"staging\"}",
          "legendFormat": "staging",
          "refId": "B"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "Prometheus" }
    },
    {
      "id": 2,
      "title": "Overdue Count",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "rr_overdue_count{env=\"prod\"}",
          "legendFormat": "prod",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "rr_overdue_count{env=\"staging\"}",
          "legendFormat": "staging",
          "refId": "B"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "Prometheus" }
    },
    {
      "id": 3,
      "title": "Scrapes per Minute (5m)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "rr_scrapes_per_min_5m{env=\"prod\"}",
          "legendFormat": "prod",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "rr_scrapes_per_min_5m{env=\"staging\"}",
          "legendFormat": "staging",
          "refId": "B"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "Prometheus" }
    },
    {
      "id": 4,
      "title": "Tracked Active Count",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "rr_tracked_active_count{env=\"prod\"}",
          "legendFormat": "prod",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "rr_tracked_active_count{env=\"staging\"}",
          "legendFormat": "staging",
          "refId": "B"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "Prometheus" }
    },
    {
      "id": 5,
      "title": "P95 Queue Wait (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "rr_p95_queue_wait_ms{env=\"prod\"}",
          "legendFormat": "prod",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "expr": "rr_p95_queue_wait_ms{env=\"staging\"}",
          "legendFormat": "staging",
          "refId": "B"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "Prometheus" }
    }
  ]
}
