services:
  postgresql:
    image: postgres:16
    container_name: authentik-postgres
    restart: unless-stopped
    environment:
      POSTGRES_PASSWORD: ${AUTHENTIK_POSTGRESQL__PASSWORD}
      POSTGRES_USER: ${AUTHENTIK_POSTGRESQL__USER}
      POSTGRES_DB: ${AUTHENTIK_POSTGRESQL__NAME}
    volumes:
      - ./postgres:/var/lib/postgresql/data

  redis:
    image: redis:7
    container_name: authentik-redis
    restart: unless-stopped

  server:
    image: ghcr.io/goauthentik/server:{{ config.authentik.version }}
    container_name: authentik-server
    restart: unless-stopped
    command: server
    env_file:
      - ./.env
    ports:
      - "{{ config.authentik.port }}:9000"
    volumes:
      - ./media:/media
      - ./templates:/templates
      - ./scripts:/scripts:ro
    depends_on:
      - postgresql
      - redis

  worker:
    image: ghcr.io/goauthentik/server:{{ config.authentik.version }}
    container_name: authentik-worker
    restart: unless-stopped
    command: worker
    env_file:
      - ./.env
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock
      - ./media:/media
      - ./templates:/templates
      - ./scripts:/scripts:ro
    depends_on:
      - postgresql
      - redis
{% if config.authentik.ldap.enabled | default(false) and authentik_ldap_outpost_token is defined %}

  ldap:
    image: ghcr.io/goauthentik/ldap:{{ config.authentik.version }}
    container_name: {{ config.authentik.ldap.outpost_container_name }}
    restart: unless-stopped
    env_file:
      - ./ldap-outpost.env
    ports:
      - "{{ config.authentik.ldap.port }}:3389"
      - "{{ config.authentik.ldap.ssl_port }}:6636"
    depends_on:
      - server
{% endif %}
