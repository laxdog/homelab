CONFIG = json.loads(
    r'''{{ {
  "proxy_apps": config.authentik.proxy_apps | default([]),
  "authentik_host": "https://%s" % (config.authentik.external_domain),
  "proxmox_oidc": {
    "name": "Proxmox OIDC",
    "slug": config.proxmox.oidc.slug,
    "redirect_uris": config.proxmox.oidc.redirect_uris,
    "client_id": proxmox_oidc_client_id,
    "client_secret": proxmox_oidc_client_secret,
    "enabled": config.proxmox.oidc.enabled | default(true)
  },
  "ldap": (config.authentik.ldap | default({"enabled": false})) | combine({
    "bind_password": authentik_jellyfin_ldap_bind_password | default("")
  })
} | to_json }}'''
)


def ensure_flow(slug, name, with_mfa):
    flow, _ = Flow.objects.update_or_create(
        slug=slug,
        defaults={
            "name": name,
            "title": name,
            "designation": "authentication",
            "authentication": "none",
        },
    )

    password, _ = PasswordStage.objects.update_or_create(
        name=f"{name} Password",
        defaults={
            "name": f"{name} Password",
            "allow_show_password": False,
            "backends": [
                "authentik.core.auth.InbuiltBackend",
                "authentik.sources.kerberos.auth.KerberosBackend",
                "authentik.sources.ldap.auth.LDAPBackend",
                "authentik.core.auth.TokenBackend",
            ],
        },
    )
    identification, _ = IdentificationStage.objects.update_or_create(
        name=f"{name} Identification",
        defaults={
            "name": f"{name} Identification",
            "user_fields": ["username", "email"],
            "password_stage": password,
        },
    )
    login, _ = UserLoginStage.objects.update_or_create(
        name=f"{name} Login",
        defaults={"name": f"{name} Login"},
    )

    bindings = [
        (10, identification),
    ]
    if with_mfa:
        totp, _ = AuthenticatorTOTPStage.objects.update_or_create(
            name=f"{name} TOTP",
            defaults={
                "name": f"{name} TOTP",
                "friendly_name": f"{name} TOTP",
                "digits": 6,
            },
        )
        mfa_validate, _ = AuthenticatorValidateStage.objects.update_or_create(
            name=f"{name} MFA Validate",
            defaults={
                "name": f"{name} MFA Validate",
                "device_classes": ["totp"],
                "not_configured_action": "configure",
            },
        )
        mfa_validate.configuration_stages.set([totp])
        bindings.append((20, mfa_validate))
        bindings.append((30, login))
    else:
        bindings.append((30, login))

    for order, stage in bindings:
        FlowStageBinding.objects.update_or_create(
            target=flow,
            stage=stage,
            defaults={"order": order, "target": flow, "stage": stage},
        )
    return flow


def ensure_proxy_app(flow, app):
    provider, _ = ProxyProvider.objects.update_or_create(
        name=f"{app['name']} Proxy",
        defaults={
            "name": f"{app['name']} Proxy",
            "mode": "forward_single",
            "external_host": app["external_host"],
            "authentication_flow": flow,
            "authorization_flow": Flow.objects.get(
                slug="default-provider-authorization-implicit-consent"
            ),
        },
    )

    Application.objects.update_or_create(
        slug=app["slug"],
        defaults={"name": app["name"], "slug": app["slug"], "provider": provider},
    )
    return provider


def update_outpost(name, outpost_type, providers, authentik_host):
    outpost = Outpost.objects.filter(name=name).first()
    if not outpost:
        outpost = Outpost.objects.create(
            name=name,
            type=outpost_type,
            config=OutpostConfig(authentik_host=authentik_host),
        )
    outpost.type = outpost_type
    outpost.config = replace(outpost.config, authentik_host=authentik_host)
    outpost.save()
    outpost.providers.set(providers)
    _ = outpost.token
    return outpost


def ensure_oidc_app(flow, oidc):
    if not oidc or not oidc.get("enabled", True):
        if oidc:
            Application.objects.filter(slug=oidc.get("slug")).delete()
            OAuth2Provider.objects.filter(name=oidc.get("name")).delete()
        return None

    redirect_uris = [
        {"matching_mode": "strict", "url": uri} for uri in oidc.get("redirect_uris", [])
    ]
    signing_key = (
        CertificateKeyPair.objects.filter(name="authentik Internal JWT Certificate").first()
        or CertificateKeyPair.objects.filter(name="authentik Self-signed Certificate").first()
    )
    provider, _ = OAuth2Provider.objects.update_or_create(
        name=oidc["name"],
        defaults={
            "name": oidc["name"],
            "authorization_flow": flow,
            "authentication_flow": flow,
            "client_type": "confidential",
            "client_id": oidc["client_id"],
            "client_secret": oidc["client_secret"],
            "_redirect_uris": redirect_uris,
            "signing_key": signing_key,
        },
    )

    Application.objects.update_or_create(
        slug=oidc["slug"],
        defaults={"name": oidc["name"], "slug": oidc["slug"], "provider": provider},
    )
    return provider


def ensure_internal_user(username, password, name):
    user, _ = User.objects.get_or_create(
        username=username,
        defaults={
            "name": name,
            "is_active": True,
            "type": "internal",
            "path": "users",
        },
    )
    dirty = False
    if user.name != name:
        user.name = name
        dirty = True
    if not user.is_active:
        user.is_active = True
        dirty = True
    if user.type != "internal":
        user.type = "internal"
        dirty = True
    if user.path != "users":
        user.path = "users"
        dirty = True
    if dirty:
        user.save()
    if password:
        user.set_password(password)
        user.save()
    return user


def ensure_ldap_provider():
    ldap = CONFIG.get("ldap", {})
    if not ldap.get("enabled"):
        return None

    bind_flow = Flow.objects.get(slug="default-authentication-flow")
    certificate = CertificateKeyPair.objects.filter(name=ldap["certificate_name"]).first()

    provider, _ = LDAPProvider.objects.update_or_create(
        name=ldap["provider_name"],
        defaults={
            "name": ldap["provider_name"],
            "authentication_flow": bind_flow,
            # Authentik's LDAP outpost currently reads bind_flow_slug from the
            # provider's authorization_flow, not authentication_flow.
            "authorization_flow": bind_flow,
            "base_dn": ldap["base_dn"],
            "certificate": certificate,
            "tls_server_name": "",
            "bind_mode": ldap["bind_mode"],
            "search_mode": ldap["search_mode"],
            "mfa_support": ldap["mfa_support"],
        },
    )

    Application.objects.update_or_create(
        slug=ldap["application_slug"],
        defaults={
            "name": ldap["application_name"],
            "slug": ldap["application_slug"],
            "provider": provider,
        },
    )

    Group.objects.update_or_create(name=ldap["user_group_name"])
    bind_user = ensure_internal_user(
        ldap["bind_user"]["username"],
        ldap["bind_password"],
        ldap["bind_user"]["name"],
    )

    if Permission.objects.filter(codename="search_full_directory").exists():
        assign_perm("search_full_directory", bind_user, provider)

    update_outpost(
        ldap["outpost_name"],
        "ldap",
        [provider],
        "http://server:9000",
    )
    return provider


def ensure_prompt(
    name,
    field_key,
    label,
    field_type,
    required=True,
    placeholder="",
    initial_value="",
):
    prompt, _ = Prompt.objects.update_or_create(
        name=name,
        defaults={
            "name": name,
            "field_key": field_key,
            "label": label,
            "type": field_type,
            "required": required,
            "placeholder": placeholder,
            "initial_value": initial_value,
        },
    )
    return prompt


def ensure_jellyfin_invite_flow():
    ldap = CONFIG.get("ldap", {})
    if not ldap.get("enabled"):
        return None

    user_group = Group.objects.get(name=ldap["user_group_name"])

    flow, _ = Flow.objects.update_or_create(
        slug="jellyfin-user-enrollment",
        defaults={
            "name": "Jellyfin User Enrollment",
            "title": "Create your Jellyfin account",
            "designation": "enrollment",
            "authentication": "none",
        },
    )

    invitation_stage, _ = InvitationStage.objects.update_or_create(
        name="Jellyfin Invite Gate",
        defaults={
            "name": "Jellyfin Invite Gate",
            "continue_flow_without_invitation": False,
        },
    )

    prompt_stage, _ = PromptStage.objects.update_or_create(
        name="Jellyfin Enrollment Prompt",
        defaults={"name": "Jellyfin Enrollment Prompt"},
    )
    prompt_stage.fields.set(
        [
            ensure_prompt(
                "Jellyfin Enrollment Username",
                "username",
                "Username",
                "username",
                placeholder="Choose a Jellyfin username",
            ),
            ensure_prompt(
                "Jellyfin Enrollment Name",
                "name",
                "Display name",
                "text",
                placeholder="Your name",
            ),
            ensure_prompt(
                "Jellyfin Enrollment Email",
                "email",
                "Email address",
                "email",
                placeholder="you@example.com",
            ),
            ensure_prompt(
                "Jellyfin Enrollment Password",
                "password",
                "Password",
                "password",
            ),
        ]
    )

    user_write_stage, _ = UserWriteStage.objects.update_or_create(
        name="Jellyfin Enrollment Write",
        defaults={
            "name": "Jellyfin Enrollment Write",
            "user_creation_mode": UserCreationMode.CREATE_WHEN_REQUIRED,
            "create_users_as_inactive": False,
            "create_users_group": user_group,
            "user_type": "internal",
            "user_path_template": "users",
        },
    )

    user_login_stage, _ = UserLoginStage.objects.update_or_create(
        name="Jellyfin Enrollment Login",
        defaults={"name": "Jellyfin Enrollment Login"},
    )

    bindings = [
        (10, invitation_stage),
        (20, prompt_stage),
        (30, user_write_stage),
        (40, user_login_stage),
    ]
    for order, stage in bindings:
        FlowStageBinding.objects.update_or_create(
            target=flow,
            stage=stage,
            defaults={"order": order, "target": flow, "stage": stage},
        )

    return flow


def main():
    mfa_flow = ensure_flow("homelab-auth-mfa", "Homelab MFA", with_mfa=True)
    ensure_oidc_app(mfa_flow, CONFIG.get("proxmox_oidc"))

    providers = [ensure_proxy_app(mfa_flow, app) for app in CONFIG["proxy_apps"]]
    if providers:
        update_outpost("authentik Embedded Outpost", "proxy", providers, CONFIG["authentik_host"])

    ensure_ldap_provider()
    ensure_jellyfin_invite_flow()


if __name__ == "__main__":
    main()
