server:
  http_listen_port: 9080
  grpc_listen_port: 0

positions:
  filename: /var/lib/promtail/positions.yaml

clients:
  - url: http://10.20.30.172:3100/loki/api/v1/push

scrape_configs:
  - job_name: journal
    journal:
      max_age: 12h
      labels:
        job: systemd-journal
        host: {{ inventory_hostname }}
    relabel_configs:
      - source_labels: [__journal__systemd_unit]
        target_label: unit
      - source_labels: [__journal__hostname]
        target_label: host

  - job_name: syslog
    static_configs:
      - targets: [localhost]
        labels:
          job: syslog
          host: {{ inventory_hostname }}
          __path__: /var/log/syslog
{% if promtail_app_logs | default(false) %}

  - job_name: app
    static_configs:
      - targets: [localhost]
        labels:
          job: {{ promtail_app_name | default('app') }}
          env: {{ promtail_app_env | default('prod') }}
          host: {{ inventory_hostname }}
          __path__: {{ promtail_app_log_path }}
{% endif %}
{% if promtail_docker_logs | default(false) %}

  - job_name: docker
    docker_sd_configs:
      - host: unix:///var/run/docker.sock
        refresh_interval: 5s
    relabel_configs:
      - source_labels: [__meta_docker_container_name]
        regex: /(.*)
        target_label: container
      - source_labels: [__meta_docker_container_log_stream]
        target_label: stream
      - action: replace
        replacement: {{ inventory_hostname }}
        target_label: host
{% endif %}
