http:
  address: "{{ config.adguard.bind_host }}:{{ config.adguard.bind_port }}"

users:
  - name: "{{ config.adguard.admin_user }}"
    password: "{{ adguard_admin_password_hash }}"

auth_attempts: 5
block_auth_min: 15

dns:
  bind_hosts:
{% for host in config.adguard.dns.bind_hosts %}
    - {{ host }}
{% endfor %}
  port: {{ config.adguard.dns.port }}
  protection_enabled: true
  filtering_enabled: true
  blocking_mode: default
  blocked_response_ttl: 10
  upstream_dns:
{% for upstream in config.adguard.dns.upstream_dns %}
    - {{ upstream }}
{% endfor %}
  bootstrap_dns:
{% for ns in config.adguard.dns.bootstrap_dns %}
    - {{ ns }}
{% endfor %}
  cache_optimistic: {{ (config.adguard.dns.cache_optimistic | default(false)) | bool | lower }}
  resolve_clients: {{ (config.adguard.dns.resolve_clients | default(false)) | bool | lower }}
  use_private_ptr_resolvers: {{ (config.adguard.dns.use_private_ptr_resolvers | default(false)) | bool | lower }}
  local_ptr_upstreams:
{% for ptr in config.adguard.dns.local_ptr_upstreams | default([]) %}
    - {{ ptr }}
{% endfor %}

filters:
{% set all_filters = config.adguard.filters.blocklists + config.adguard.filters.allowlists %}
{% for filt in all_filters %}
  - enabled: {{ filt.enabled | bool | lower }}
    url: "{{ filt.url }}"
    name: "{{ filt.name }}"
    id: {{ loop.index }}
{% endfor %}

user_rules:
{% for rule in config.adguard.user_rules | default([]) %}
  - {{ rule | to_json }}
{% endfor %}

clients:
  runtime_sources:
    whois: true
    arp: true
    rdns: true
    dhcp: true
    hosts: true
  persistent:
{% for c in config.adguard.client_overrides | default([]) %}
    - safe_search:
        enabled: false
        bing: false
        duckduckgo: false
        ecosia: false
        google: false
        pixabay: false
        yandex: false
        youtube: false
      blocked_services:
        schedule:
          time_zone: Local
        ids: []
      name: "{{ c.name }}"
      ids:
{% for id in c.ids | default([]) %}
        - "{{ id }}"
{% endfor %}
      tags: []
      upstreams: []
      uid: "{{ c.name | to_uuid }}"
      upstreams_cache_size: 0
      upstreams_cache_enabled: false
      use_global_settings: {{ (c.use_global_settings | default(true)) | bool | lower }}
      filtering_enabled: {{ (c.filtering_enabled | default(true)) | bool | lower }}
      parental_enabled: false
      safebrowsing_enabled: false
      use_global_blocked_services: {{ (c.use_global_blocked_services | default(true)) | bool | lower }}
      ignore_querylog: false
      ignore_statistics: false
{% endfor %}

filtering:
  safe_search:
    enabled: {{ (config.adguard.filtering.safe_search.enabled | default(false)) | bool | lower }}
    bing: {{ (config.adguard.filtering.safe_search.bing | default(false)) | bool | lower }}
    duckduckgo: {{ (config.adguard.filtering.safe_search.duckduckgo | default(false)) | bool | lower }}
    ecosia: {{ (config.adguard.filtering.safe_search.ecosia | default(false)) | bool | lower }}
    google: {{ (config.adguard.filtering.safe_search.google | default(false)) | bool | lower }}
    pixabay: {{ (config.adguard.filtering.safe_search.pixabay | default(false)) | bool | lower }}
    yandex: {{ (config.adguard.filtering.safe_search.yandex | default(false)) | bool | lower }}
    youtube: {{ (config.adguard.filtering.safe_search.youtube | default(false)) | bool | lower }}
  rewrites_enabled: true
  rewrites:
{% for rewrite in config.adguard.rewrites | default([]) %}
    - domain: "{{ rewrite.domain }}"
      answer: "{{ rewrite.answer }}"
      enabled: true
{% endfor %}

# Pin the schema version so AdGuard does NOT run its config_migrator on our
# rendered file. We write schema-33 shape (clients as map, bootstrap_dns as
# list, etc.); without this pin, AdGuard sees missing schema_version, assumes
# schema 0, runs 0→33 migrations, and crashes at the 5→6 step when it finds
# our already-v33-shaped clients key. Bump this number if we ever move to a
# newer AdGuard whose internal schema_version has advanced.
schema_version: 33
