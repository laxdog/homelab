services:
  netalertx:
    image: ghcr.io/jokob-sk/netalertx:latest
    container_name: netalertx
    restart: unless-stopped
    network_mode: host
    cap_add:
      - NET_ADMIN
      - NET_RAW
      - NET_BIND_SERVICE
    environment:
      TZ: "{{ config.homelab.timezone }}"
      PUID: "1000"
      PGID: "1000"
    volumes:
      - ./data:/app/config
